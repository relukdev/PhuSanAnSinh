<!-- Booking Bottom Sheet — Universal form for all service types -->
<div class="booking-backdrop" id="booking-backdrop"></div>
<div
  class="booking-sheet"
  id="booking-sheet"
  role="dialog"
  aria-modal="true"
  aria-label="Đặt lịch khám"
>
  <div class="booking-handle"><span></span></div>
  <div class="booking-header">
    <div class="booking-header-info">
      <span class="booking-icon" id="booking-icon">📋</span>
      <div>
        <h3 id="booking-title">Đặt Lịch Khám</h3>
        <p id="booking-hint">Bác sĩ sẽ liên hệ bạn trong 30 phút</p>
      </div>
    </div>
    <button class="booking-close" id="booking-close" aria-label="Đóng">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  <form class="booking-form" id="booking-form" novalidate>
    <input type="hidden" name="url" value="">
    <input type="hidden" name="formType" value="">

    <div class="booking-field">
      <label for="booking-phone">Số điện thoại <span class="required-mark">*</span></label>
      <input type="tel" id="booking-phone" name="phone" placeholder="Nhập số điện thoại" required autocomplete="tel" inputmode="numeric" pattern="0[0-9]{8,10}">
    </div>

    <div class="booking-field">
      <label for="booking-name">Họ và tên</label>
      <input type="text" id="booking-name" name="name" placeholder="VD: Nguyễn Thị Hoa" autocomplete="name">
    </div>

    <div class="booking-field">
      <label>Ngày muốn khám</label>
      <div class="booking-date-chips" id="booking-date-chips">
        <!-- Rendered dynamically by JS -->
      </div>
      <div class="booking-date-custom" id="booking-date-custom" hidden>
        <input type="date" id="booking-date-input" name="dateCustom">
      </div>
      <input type="hidden" name="date" id="booking-date" value="">
    </div>

    <div class="booking-field" id="booking-time-field" hidden>
      <label>Khung giờ muốn tới</label>
      <div class="booking-time-chips" id="booking-time-chips">
        <!-- Rendered dynamically by JS based on selected date -->
      </div>
      <input type="hidden" name="timeSlot" id="booking-time" value="">
    </div>

    <div class="booking-service-hint" id="booking-service-hint" hidden>
      <span class="hint-icon">💡</span>
      <span class="hint-text" id="booking-service-hint-text"></span>
    </div>

    <div class="booking-field">
      <label for="booking-service">Dịch vụ</label>
      <select id="booking-service" name="service">
        <option value="">— Chọn dịch vụ —</option>
        <option value="Khám thai định kỳ">Khám thai định kỳ</option>
        <option value="Siêu âm 5D">Siêu âm 5D</option>
        <option value="Khám phụ khoa">Khám phụ khoa</option>
        <option value="Khám nam khoa">Khám nam khoa</option>
        <option value="Điều trị vô sinh">Điều trị vô sinh</option>
        <option value="Tư vấn tránh thai">Tư vấn tránh thai</option>
        <option value="Tư vấn chung">Tư vấn chung</option>
      </select>
    </div>

    <div class="booking-field">
      <label for="booking-note">Lưu ý cho bác sĩ <span class="optional">(tuỳ chọn)</span></label>
      <textarea id="booking-note" name="note" placeholder="VD: Muốn khám với BS nữ, đã có kết quả xét nghiệm..." rows="2"></textarea>
    </div>

    <button type="submit" class="booking-submit" id="booking-submit">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"></path><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
      Xác Nhận Đặt Lịch
    </button>

    <p class="booking-privacy">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
      Thông tin được bảo mật. Bác sĩ sẽ liên hệ bạn sớm nhất.
    </p>
  </form>
</div>

<!-- Toast Notification -->
<div class="form-toast" id="form-toast" role="alert" aria-live="polite" hidden>
  <div class="form-toast-content">
    <span class="form-toast-icon" id="form-toast-icon"></span>
    <span class="form-toast-msg" id="form-toast-msg"></span>
  </div>
  <button class="form-toast-close" id="form-toast-close" aria-label="Đóng">×</button>
</div>

<style>
  /* ── Booking Bottom Sheet ── */
  .booking-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 10000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .booking-backdrop.is-visible {
    opacity: 1;
    visibility: visible;
  }

  .booking-sheet {
    position: fixed;
    z-index: 10001;
    background: #fff;
    border-radius: 20px 20px 0 0;
    box-shadow: 0 -8px 40px rgba(0,0,0,0.18);
    max-height: 90vh;
    overflow-y: auto;
    overscroll-behavior: contain;
    bottom: 0;
    left: 0;
    right: 0;
    transform: translateY(100%);
    transition: transform 0.38s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .booking-sheet.is-open {
    transform: translateY(0);
  }

  .booking-handle {
    display: flex;
    justify-content: center;
    padding: 10px 0 4px;
    cursor: grab;
  }
  .booking-handle span {
    width: 40px;
    height: 4px;
    background: #d1d5db;
    border-radius: 2px;
  }

  .booking-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 1.25rem 0.75rem;
  }
  .booking-header-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .booking-icon {
    font-size: 1.75rem;
    line-height: 1;
  }
  .booking-header-info h3 {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }
  .booking-header-info p {
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin: 2px 0 0;
  }

  .booking-close {
    background: none;
    border: none;
    padding: 6px;
    cursor: pointer;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    transition: all 0.15s;
  }
  .booking-close:hover {
    background: var(--surface-alt);
    color: var(--text-primary);
  }

  /* ── Form Fields ── */
  .booking-form {
    padding: 0 1.25rem 1.5rem;
  }

  .booking-field {
    margin-bottom: 1rem;
  }
  .booking-field label {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 0.375rem;
  }
  .booking-field .optional {
    font-weight: 400;
    color: var(--text-muted);
  }
  .required-mark {
    color: var(--accent, #e74c3c);
    font-weight: 700;
  }

  .booking-field input[type="text"],
  .booking-field input[type="tel"],
  .booking-field select,
  .booking-field textarea {
    width: 100%;
    padding: 0.625rem 0.875rem;
    border: 1.5px solid var(--border-light);
    border-radius: var(--radius-md);
    font-size: 0.9375rem;
    font-family: var(--font-body);
    color: var(--text-primary);
    background: #fff;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
  }
  .booking-field input:focus,
  .booking-field select:focus,
  .booking-field textarea:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(var(--primary-rgb, 37,99,235), 0.1);
  }
  .booking-field textarea {
    resize: vertical;
    min-height: 56px;
  }

  /* Service hint */
  .booking-service-hint {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    background: #fff7ed;
    border: 1px solid #fed7aa;
    border-radius: var(--radius-md);
    margin-bottom: 1rem;
    font-size: 0.8125rem;
    color: #9a3412;
    line-height: 1.5;
  }
  .booking-service-hint[hidden] { display: none; }
  .hint-icon { font-size: 1rem; flex-shrink: 0; }

  /* UX: Fitts's Law — Grid layout with uniform touch targets ≥ 44px */
  .booking-date-chips {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }
  .date-chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.5rem 0.375rem;
    border: 1.5px solid var(--border-light);
    border-radius: var(--radius-md);
    background: #fff;
    font-family: var(--font-body);
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, color 0.2s, box-shadow 0.2s;
    text-align: center;
    color: var(--text-secondary);
    line-height: 1.3;
    -webkit-tap-highlight-color: transparent;
  }
  /* UX: Aesthetic-Usability — recommended chip subtle highlight */
  .date-chip.is-recommended {
    border-color: var(--primary);
    background: rgba(var(--primary-rgb, 37,99,235), 0.04);
  }
  .date-chip:hover {
    border-color: var(--primary);
    color: var(--primary);
    box-shadow: 0 1px 4px rgba(var(--primary-rgb, 37,99,235), 0.1);
  }
  .date-chip:active {
    transform: scale(0.97);
  }
  .date-chip.is-active {
    background: var(--primary);
    border-color: var(--primary);
    color: #fff;
    box-shadow: 0 2px 8px rgba(var(--primary-rgb, 37,99,235), 0.25);
  }
  .date-chip .date-chip-label {
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.2;
  }
  .date-chip .date-chip-sub {
    display: block;
    font-size: 0.6875rem;
    font-weight: 400;
    opacity: 0.6;
    margin-top: 2px;
    line-height: 1.2;
  }
  .date-chip.is-active .date-chip-sub {
    opacity: 0.85;
  }
  .date-chip.is-recommended .date-chip-label {
    color: var(--primary);
  }
  .date-chip.is-active .date-chip-label {
    color: #fff;
  }
  /* Custom date chip — icon + text inline */
  .date-chip--custom {
    flex-direction: row;
    gap: 0.375rem;
  }
  .date-chip--custom svg {
    flex-shrink: 0;
  }
  .booking-date-custom {
    margin-top: 0.5rem;
  }
  .booking-date-custom input[type="date"] {
    width: 100%;
    padding: 0.625rem 0.875rem;
    border: 1.5px solid var(--border-light);
    border-radius: var(--radius-md);
    font-size: 0.9375rem;
    font-family: var(--font-body);
    color: var(--text-primary);
    background: #fff;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
  }
  .booking-date-custom input[type="date"]:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(var(--primary-rgb, 37,99,235), 0.1);
  }

  /* Time chips */
  .booking-time-chips {
    display: flex;
    gap: 0.5rem;
  }
  .time-chip {
    flex: 1;
    padding: 0.5rem 0.25rem;
    border: 1.5px solid var(--border-light);
    border-radius: var(--radius-md);
    background: #fff;
    font-size: 0.8125rem;
    font-weight: 500;
    font-family: var(--font-body);
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
    color: var(--text-secondary);
  }
  .time-chip:hover {
    border-color: var(--primary);
    color: var(--primary);
  }
  .time-chip.is-active {
    background: var(--primary);
    border-color: var(--primary);
    color: #fff;
  }

  /* Submit */
  .booking-submit {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem;
    background: var(--accent, #e74c3c);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    font-size: 1rem;
    font-weight: 700;
    font-family: var(--font-body);
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 0.25rem;
  }
  .booking-submit:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }
  .booking-submit:active {
    transform: translateY(0);
  }
  .booking-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .booking-privacy {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.75rem;
    justify-content: center;
  }

  /* ── Toast ── */
  .form-toast {
    position: fixed;
    bottom: 80px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    z-index: 10010;
    background: #1a1a2e;
    color: #fff;
    border-radius: var(--radius-lg);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
    max-width: calc(100vw - 2rem);
    width: max-content;
    opacity: 0;
    transition: opacity 0.3s, transform 0.3s;
  }
  .form-toast:not([hidden]) {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .form-toast--success { border-left: 4px solid #22c55e; }
  .form-toast--error { border-left: 4px solid #ef4444; }
  .form-toast--retrying { border-left: 4px solid #f59e0b; }

  .form-toast-content {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
  }
  .form-toast-icon { font-size: 1.125rem; }
  .form-toast-close {
    background: none;
    border: none;
    color: rgba(255,255,255,0.6);
    font-size: 1.25rem;
    cursor: pointer;
    padding: 0 0.25rem;
    line-height: 1;
  }
  .form-toast-close:hover { color: #fff; }

  /* ── Desktop: center sheet ── */
  @media (min-width: 640px) {
    .booking-sheet {
      max-width: 480px;
      left: 50%;
      right: auto;
      transform: translateX(-50%) translateY(100%);
      border-radius: 20px 20px 0 0;
    }
    .booking-sheet.is-open {
      transform: translateX(-50%) translateY(0);
    }
  }

  /* Safe area for iOS */
  @supports (padding-bottom: env(safe-area-inset-bottom)) {
    .booking-form {
      padding-bottom: calc(1.5rem + env(safe-area-inset-bottom));
    }
  }
</style>
