---
import "../../styles/global.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
const title = "Bishop Score — Tư Vấn Khởi Phát Chuyển Dạ | An Sinh";
const description =
    "Công cụ tính Bishop Score đánh giá cổ tử cung trước khởi phát chuyển dạ. Phân loại theo ACOG, SOGC 2022. Gợi ý phương pháp IOL. Tạo prompt AI. Miễn phí, chạy offline.";
---

<BaseLayout title={title} description={description}>
    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "FAQPage",
            mainEntity: [
                {
                    "@type": "Question",
                    name: "Bishop Score là gì?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Bishop Score (Edward Bishop, 1964) là hệ thống chấm điểm cổ tử cung 0–13 điểm để tiên lượng khả năng thành công của khởi phát chuyển dạ. Được ACOG, RCOG, SOGC, WHO khuyến cáo.",
                    },
                },
                {
                    "@type": "Question",
                    name: "Bishop Score bao nhiêu thì thuận lợi?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Con so (nulliparous) cần Bishop ≥ 8, con rạ (multiparous) cần ≥ 6. Score ≤ 5 là không thuận lợi, cần cervical ripening trước khởi phát.",
                    },
                },
                {
                    "@type": "Question",
                    name: "Sẹo mổ cũ có ảnh hưởng gì?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Tiền sử mổ lấy thai là chống chỉ định dùng Prostaglandin (Misoprostol, Dinoprostone) vì nguy cơ vỡ tử cung. Chỉ dùng Foley catheter hoặc Oxytocin liều thấp.",
                    },
                },
            ],
        })}
    ></script>

    <!-- Hero -->
    <section class="bs-hero">
        <div class="container">
            <div class="hero-badge">
                <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    ><path d="M22 11.08V12a10 10 0 11-5.93-9.14"
                    ></path><polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                ACOG · SOGC 2022 · Miễn phí 100%
            </div>
            <h1>
                Bishop Score — <span class="text-accent-color"
                    >Khởi Phát Chuyển Dạ</span>
            </h1>
            <p class="hero-sub">
                Đánh giá cổ tử cung, phân loại theo ngưỡng con so / con rạ. Gợi
                ý phương pháp khởi phát. Tạo prompt AI để tư vấn chi tiết. Toàn
                bộ logic chạy trên trình duyệt — không lưu dữ liệu.
            </p>
        </div>
    </section>

    <!-- Tool -->
    <section class="bs-section">
        <div class="container">
            <div class="bs-grid">
                <!-- Input Panel -->
                <div class="bs-input-panel card">
                    <h2 class="bs-panel-title">
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--primary)"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                            ><path
                                d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"
                            ></path><rect
                                x="8"
                                y="2"
                                width="8"
                                height="4"
                                rx="1"
                                ry="1"></rect>
                        </svg>
                        Khám Cổ Tử Cung
                    </h2>

                    <form id="bs-form" novalidate>
                        <!-- A. Cervical Parameters -->
                        <div class="form-section-label">
                            A. Thông số cổ tử cung (Bishop)
                        </div>

                        <!-- Dilation -->
                        <div class="form-group">
                            <label class="form-label"
                                >Độ mở CTC (Dilation)</label
                            >
                            <div class="toggle-group">
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="dilation"
                                        value="closed"
                                    /><span>Đóng kín</span>
                                </label>
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="dilation"
                                        value="1-2"
                                    /><span>1–2 cm</span>
                                </label>
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="dilation"
                                        value="3-4"
                                    /><span>3–4 cm</span>
                                </label>
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="dilation"
                                        value=">=5"
                                    /><span>≥ 5 cm</span>
                                </label>
                            </div>
                        </div>

                        <!-- Effacement -->
                        <div class="form-group">
                            <label class="form-label"
                                >Độ xóa CTC (Effacement)</label
                            >
                            <div class="toggle-group">
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="effacement"
                                        value="0-30"
                                    /><span>0–30%</span>
                                </label>
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="effacement"
                                        value="40-50"
                                    /><span>40–50%</span>
                                </label>
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="effacement"
                                        value="60-70"
                                    /><span>60–70%</span>
                                </label>
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="effacement"
                                        value=">=80"
                                    /><span>≥ 80%</span>
                                </label>
                            </div>
                        </div>

                        <!-- Station -->
                        <div class="form-group">
                            <label class="form-label"
                                >Độ lọt ngôi (Station)</label
                            >
                            <div class="toggle-group">
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="station"
                                        value="-3"
                                    /><span>−3</span>
                                </label>
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="station"
                                        value="-2"
                                    /><span>−2</span>
                                </label>
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="station"
                                        value="-1,0"
                                    /><span>−1, 0</span>
                                </label>
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="station"
                                        value="+1,+2"
                                    /><span>+1, +2</span>
                                </label>
                            </div>
                        </div>

                        <!-- Consistency -->
                        <div class="form-group">
                            <label class="form-label"
                                >Mật độ CTC (Consistency)</label
                            >
                            <div class="toggle-group">
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="consistency"
                                        value="firm"
                                    /><span>Cứng</span>
                                </label>
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="consistency"
                                        value="medium"
                                    /><span>Trung bình</span>
                                </label>
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="consistency"
                                        value="soft"
                                    /><span>Mềm</span>
                                </label>
                            </div>
                        </div>

                        <!-- Position -->
                        <div class="form-group">
                            <label class="form-label"
                                >Vị trí CTC (Position)</label
                            >
                            <div class="toggle-group">
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="position"
                                        value="posterior"
                                    /><span>Sau</span>
                                </label>
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="position"
                                        value="middle"
                                    /><span>Trung gian</span>
                                </label>
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="position"
                                        value="anterior"
                                    /><span>Trước</span>
                                </label>
                            </div>
                        </div>

                        <hr class="form-divider" />
                        <!-- B. Clinical Context -->
                        <div class="form-section-label">
                            B. Ngữ cảnh lâm sàng
                        </div>

                        <div class="form-group">
                            <label class="form-label">Tình trạng sản</label>
                            <div class="toggle-group toggle-sm">
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="parity"
                                        value="nulliparous"
                                        checked
                                    /><span>Con so</span>
                                </label>
                                <label class="radio-card"
                                    ><input
                                        type="radio"
                                        name="parity"
                                        value="multiparous"
                                    /><span>Con rạ</span>
                                </label>
                            </div>
                            <small class="form-help"
                                >Con so cần Bishop ≥ 8, con rạ cần ≥ 6 để xem là
                                thuận lợi (CMQCC).</small
                            >
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="bs-ga-weeks" class="form-label"
                                    >Tuổi thai (tuần)</label
                                >
                                <input
                                    type="number"
                                    id="bs-ga-weeks"
                                    class="form-input"
                                    min="20"
                                    max="42"
                                    placeholder="VD: 39"
                                />
                            </div>
                            <div class="form-group">
                                <label for="bs-ga-days" class="form-label"
                                    >Ngày</label
                                >
                                <input
                                    type="number"
                                    id="bs-ga-days"
                                    class="form-input"
                                    min="0"
                                    max="6"
                                    placeholder="0–6"
                                />
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="bs-efw" class="form-label"
                                >EFW — Cân nặng thai ước lượng (g)</label
                            >
                            <input
                                type="number"
                                id="bs-efw"
                                class="form-input"
                                min="500"
                                max="6000"
                                placeholder="VD: 3200"
                            />
                        </div>

                        <div class="checkbox-grid">
                            <label class="checkbox-label"
                                ><input type="checkbox" id="bs-prior-cs" /><span
                                    >Tiền sử mổ lấy thai (sẹo mổ cũ)</span
                                >
                            </label>
                            <label class="checkbox-label"
                                ><input type="checkbox" id="bs-rom" /><span
                                    >Ối đã vỡ (PROM)</span
                                >
                            </label>
                        </div>

                        <div class="form-group">
                            <label for="bs-comorbidity" class="form-label"
                                >Bệnh lý kèm theo</label
                            >
                            <select id="bs-comorbidity" class="form-input">
                                <option value="none">Không</option>
                                <option value="preeclampsia"
                                    >Tiền sản giật</option
                                >
                                <option value="gdm"
                                    >Đái tháo đường thai kỳ</option
                                >
                                <option value="postterm">Thai quá ngày</option>
                                <option value="other">Khác</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="bs-reason" class="form-label"
                                >Lý do xem xét khởi phát</label
                            >
                            <select id="bs-reason" class="form-input">
                                <option value="">Chọn...</option>
                                <option value="postterm">Thai quá ngày</option>
                                <option value="preeclampsia"
                                    >Tiền sản giật</option
                                >
                                <option value="prom">Ối vỡ non</option>
                                <option value="gdm"
                                    >Đái tháo đường thai kỳ</option
                                >
                                <option value="elective">Chọn lựa</option>
                                <option value="other">Khác</option>
                            </select>
                        </div>

                        <!-- Validation Error -->
                        <div
                            id="bs-validation-error"
                            class="validation-error"
                            role="alert"
                            aria-live="polite"
                            hidden
                        >
                        </div>

                        <button
                            type="submit"
                            class="btn btn-accent btn-lg bs-submit"
                            id="bs-submit-btn"
                        >
                            <svg
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                aria-hidden="true"
                                ><path d="M22 11.08V12a10 10 0 11-5.93-9.14"
                                ></path><polyline points="22 4 12 14.01 9 11.01"
                                ></polyline>
                            </svg>
                            Tính Bishop Score
                        </button>
                    </form>
                </div>

                <!-- Results Panel -->
                <div class="bs-results-panel" id="bs-results" hidden>
                    <!-- Score Header -->
                    <div
                        class="result-card result-primary card"
                        id="bs-risk-header"
                    >
                        <div class="result-icon-wrap">
                            <span class="result-emoji" id="bs-emoji">—</span>
                        </div>
                        <div class="result-content">
                            <span class="result-label">Bishop Score</span>
                            <div
                                class="result-risk-level"
                                id="bs-score-display"
                            >
                                —/13
                            </div>
                            <div class="result-sub" id="bs-class-label"></div>
                        </div>
                    </div>

                    <!-- Score Breakdown -->
                    <div class="card result-card">
                        <h3 class="card-title">
                            <svg
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="var(--primary)"
                                stroke-width="2"
                                aria-hidden="true"
                                ><rect
                                    x="3"
                                    y="3"
                                    width="18"
                                    height="18"
                                    rx="2"
                                    ry="2"></rect><line
                                    x1="3"
                                    y1="9"
                                    x2="21"
                                    y2="9"></line><line
                                    x1="9"
                                    y1="21"
                                    x2="9"
                                    y2="9"></line>
                            </svg>
                            Chi tiết điểm số
                        </h3>
                        <div class="threshold-table-wrap">
                            <table
                                class="threshold-table"
                                id="bs-breakdown-table"
                            >
                                <thead
                                    ><tr
                                        ><th>Thông số</th><th>Giá trị</th><th
                                            >Điểm</th
                                        >
                                    </tr>
                                </thead>
                                <tbody id="bs-breakdown-body"></tbody>
                                <tfoot
                                    ><tr
                                        style="font-weight:700;background:var(--surface-alt)"
                                        ><td colspan="2">Tổng Bishop Score</td
                                        ><td id="bs-total-cell">—</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>

                    <!-- Parity Assessment -->
                    <div class="card result-card" id="bs-parity-card">
                        <h3 class="card-title">
                            <svg
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="var(--primary)"
                                stroke-width="2"
                                aria-hidden="true"
                                ><circle cx="12" cy="12" r="10"></circle><line
                                    x1="12"
                                    y1="8"
                                    x2="12"
                                    y2="12"></line><line
                                    x1="12"
                                    y1="16"
                                    x2="12.01"
                                    y2="16"></line>
                            </svg>
                            Đánh giá theo tình trạng sản
                        </h3>
                        <div id="bs-parity-content"></div>
                    </div>

                    <!-- Induction Methods -->
                    <div class="card result-card">
                        <h3 class="card-title">
                            <svg
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="var(--primary)"
                                stroke-width="2"
                                aria-hidden="true"
                                ><path
                                    d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"
                                ></path><polyline points="14 2 14 8 20 8"
                                ></polyline>
                            </svg>
                            Phương pháp khởi phát đề xuất
                        </h3>
                        <div id="bs-methods-list"></div>
                        <div id="bs-warnings-list"></div>
                    </div>

                    <!-- Dosage Reference -->
                    <details class="bs-details card">
                        <summary class="bs-summary">
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                aria-hidden="true"
                                ><path d="M4 19.5A2.5 2.5 0 016.5 17H20"
                                ></path><path
                                    d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"
                                ></path>
                            </svg>
                            Liều lượng tham chiếu
                        </summary>
                        <div id="bs-dosage-content"></div>
                    </details>

                    <!-- Citations -->
                    <details class="bs-details card">
                        <summary class="bs-summary">
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                aria-hidden="true"
                                ><path d="M4 19.5A2.5 2.5 0 016.5 17H20"
                                ></path><path
                                    d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"
                                ></path>
                            </svg>
                            Trích dẫn y khoa
                        </summary>
                        <div class="bs-citations">
                            <p>
                                1. Bishop EH. Pelvic Scoring for Elective
                                Induction. <em>Obstet Gynecol.</em> 1964;24:266-268.
                            </p>
                            <p>
                                2. SOGC Guideline No. 432c: Induction of Labour. <em
                                    >J Obstet Gynaecol Can.</em
                                > 2022.
                            </p>
                            <p>
                                3. Wheeler V, et al. Cervical Ripening and
                                Induction of Labor. <em>Am Fam Physician.</em> 2022;105(2):177-186.
                            </p>
                            <p>
                                4. Wormer KC, et al. Bishop Score. <em
                                    >StatPearls.</em
                                > Updated Jul 17, 2024.
                            </p>
                            <p>
                                5. ACOG Practice Bulletin No. 107: Induction of
                                Labor. 2009.
                            </p>
                            <p>
                                6. Grobman WA et al. (ARRIVE Trial) <em
                                    >N Engl J Med.</em
                                > 2018;379(6):513-523.
                            </p>
                            <p>7. CMQCC Induction of Labor Toolkit.</p>
                        </div>
                    </details>

                    <!-- Prompt Section -->
                    <div class="card result-card prompt-card">
                        <h3 class="card-title">
                            <svg
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="var(--accent)"
                                stroke-width="2"
                                aria-hidden="true"
                                ><path
                                    d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"
                                ></path>
                            </svg>
                            Prompt cho AI — Gợi ý lâm sàng
                        </h3>
                        <p class="prompt-desc">
                            Copy prompt bên dưới → Paste vào ChatGPT, Claude,
                            hoặc Gemini để nhận phân tích lâm sàng chi tiết.
                        </p>
                        <div class="prompt-output" id="bs-prompt-output"></div>
                        <button
                            class="btn btn-accent btn-lg bs-submit"
                            id="bs-copy-btn"
                            type="button"
                        >
                            <svg
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                aria-hidden="true"
                                ><rect
                                    x="9"
                                    y="9"
                                    width="13"
                                    height="13"
                                    rx="2"
                                    ry="2"></rect><path
                                    d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"
                                ></path>
                            </svg>
                            <span id="bs-copy-text">Copy Prompt</span>
                        </button>
                    </div>

                    <!-- Print -->
                    <button
                        type="button"
                        class="btn btn-outline bs-print-btn"
                        id="bs-print-btn"
                    >
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            aria-hidden="true"
                            ><polyline points="6 9 6 2 18 2 18 9"
                            ></polyline><path
                                d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"
                            ></path><rect x="6" y="14" width="12" height="8"
                            ></rect>
                        </svg>
                        In kết quả
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- Reference Table -->
    <section class="section section-alt" id="bang-tham-chieu">
        <div class="container">
            <div class="section-header">
                <span class="section-label">Tham khảo</span>
                <h2>Bảng Chấm Điểm Bishop Gốc</h2>
                <p>
                    Hệ thống chấm điểm cổ tử cung 5 thông số (Edward Bishop,
                    1964). Tổng điểm tối đa: 13.
                </p>
            </div>
            <div class="card ref-card" style="max-width:720px;margin:0 auto">
                <table class="ref-table">
                    <thead
                        ><tr
                            ><th>Thông số</th><th>0 điểm</th><th>1 điểm</th><th
                                >2 điểm</th
                            ><th>3 điểm</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr
                            ><td><strong>Độ mở</strong></td><td>Đóng kín</td><td
                                >1–2 cm</td
                            ><td>3–4 cm</td><td>≥ 5 cm</td>
                        </tr>
                        <tr
                            ><td><strong>Độ xóa</strong></td><td>0–30%</td><td
                                >40–50%</td
                            ><td>60–70%</td><td>≥ 80%</td>
                        </tr>
                        <tr
                            ><td><strong>Độ lọt ngôi</strong></td><td>−3</td><td
                                >−2</td
                            ><td>−1, 0</td><td>+1, +2</td>
                        </tr>
                        <tr
                            ><td><strong>Mật độ</strong></td><td>Cứng</td><td
                                >Trung bình</td
                            ><td>Mềm</td><td>—</td>
                        </tr>
                        <tr
