    <script>
        import {
            calcBishopScore,
            classifyBishop,
            getInductionMethods,
            buildBishopPrompt,
            validateBishopInputs,
        } from "../../utils/bishop-score-calc.js";

        const form = document.getElementById("bs-form");
        const resultsPanel = document.getElementById("bs-results");
        const errorEl = document.getElementById("bs-validation-error");

        const PARAM_LABELS = {
            dilation: "Độ mở CTC",
            effacement: "Độ xóa CTC",
            station: "Độ lọt ngôi",
            consistency: "Mật độ CTC",
            position: "Vị trí CTC",
        };
        const VALUE_LABELS = {
            dilation: {
                closed: "Đóng kín",
                "1-2": "1–2 cm",
                "3-4": "3–4 cm",
                ">=5": "≥ 5 cm",
            },
            effacement: {
                "0-30": "0–30%",
                "40-50": "40–50%",
                "60-70": "60–70%",
                ">=80": "≥ 80%",
            },
            station: {
                "-3": "−3",
                "-2": "−2",
                "-1,0": "−1, 0",
                "+1,+2": "+1, +2",
            },
            consistency: { firm: "Cứng", medium: "Trung bình", soft: "Mềm" },
            position: {
                posterior: "Sau",
                middle: "Trung gian",
                anterior: "Trước",
            },
        };

        form.addEventListener("submit", (e) => {
            e.preventDefault();
            hideError();

            const fd = collectFormData();
            const validation = validateBishopInputs(fd);
            if (!validation.valid) return showError(validation.error);

            const score = calcBishopScore(fd);
            const classification = classifyBishop(score.total, fd.parity);
            const methods = getInductionMethods({
                score: score.total,
                parity: fd.parity,
                hasPriorCS: fd.hasPriorCS,
                hasROM: fd.hasROM,
            });
            const result = { score, classification, methods };

            displayResults(fd, result);

            const prompt = buildBishopPrompt(fd, result);
            document.getElementById("bs-prompt-output").textContent = prompt;

            resultsPanel.hidden = false;
            resultsPanel.scrollIntoView({ behavior: "smooth", block: "start" });
        });

        function collectFormData() {
            const getRadio = (name) =>
                document.querySelector(`input[name="${name}"]:checked`)
                    ?.value || "";
            return {
                dilation: getRadio("dilation"),
                effacement: getRadio("effacement"),
                station: getRadio("station"),
                consistency: getRadio("consistency"),
                position: getRadio("position"),
                parity: getRadio("parity"),
                gaWeeks: document.getElementById("bs-ga-weeks").value
                    ? parseInt(document.getElementById("bs-ga-weeks").value, 10)
                    : null,
                gaDays: document.getElementById("bs-ga-days").value
                    ? parseInt(document.getElementById("bs-ga-days").value, 10)
                    : null,
                efw: document.getElementById("bs-efw").value
                    ? parseInt(document.getElementById("bs-efw").value, 10)
                    : null,
                hasPriorCS: document.getElementById("bs-prior-cs").checked,
                hasROM: document.getElementById("bs-rom").checked,
                comorbidity: document.getElementById("bs-comorbidity").value,
                inductionReason: document.getElementById("bs-reason").value,
            };
        }

        function displayResults(fd, result) {
            const { score, classification, methods } = result;

            // Header
            const header = document.getElementById("bs-risk-header");
            header.className = `result-card result-primary card risk-${classification.color}`;
            document.getElementById("bs-emoji").textContent =
                classification.emoji;
            document.getElementById(
                "bs-score-display"
            ).textContent = `${score.total}/13`;
            document.getElementById("bs-class-label").textContent =
                classification.label;

            // Breakdown table
            const tbody = document.getElementById("bs-breakdown-body");
            tbody.innerHTML = [
                "dilation",
                "effacement",
                "station",
                "consistency",
                "position",
            ]
                .map(
                    (key) =>
                        `<tr><td>${PARAM_LABELS[key]}</td><td>${
                            VALUE_LABELS[key][fd[key]] || fd[key]
                        }</td><td style="font-weight:700">${
                            score.breakdown[key]
                        }</td></tr>`
                )
                .join("");
            document.getElementById("bs-total-cell").textContent = score.total;

            // Parity assessment
            const parityBox = document.getElementById("bs-parity-content");
            const parityName =
                fd.parity === "nulliparous" ? "Con so" : "Con rạ";
            parityBox.innerHTML = `<div class="parity-box ${
                classification.meetsThreshold ? "meets" : "not-meets"
            }">
    ${parityName} — ngưỡng cần ≥ ${classification.threshold} → Bishop ${
                score.total
            } → <strong>${
                classification.meetsThreshold ? "✅ ĐẠT" : "⚠️ CHƯA ĐẠT"
            }</strong>
  </div>`;

            // Methods
            const methodsDiv = document.getElementById("bs-methods-list");
            methodsDiv.innerHTML = methods.methods
                .map(
                    (m, i) =>
                        `<div class="method-item">
      <span class="method-priority">Ưu tiên ${m.priority}</span>
      <div class="method-name">${m.name}</div>
      <div class="method-detail">${m.detail}</div>
    </div>`
                )
                .join("");

            // Warnings
            const warningsDiv = document.getElementById("bs-warnings-list");
            warningsDiv.innerHTML = methods.warnings
                .map((w) => `<div class="warning-item">${w}</div>`)
                .join("");

            // Dosage
            const dosageDiv = document.getElementById("bs-dosage-content");
            const d = methods.dosageInfo;
            dosageDiv.innerHTML = `
    <div class="dosage-group"><div class="dosage-title">Oxytocin (Pitocin)</div>
      <div class="dosage-item">Low-dose: ${d.oxytocin.lowDose}</div>
      <div class="dosage-item">High-dose: ${d.oxytocin.highDose}</div>
    </div>
    <div class="dosage-group"><div class="dosage-title">Misoprostol</div>
      <div class="dosage-item">Đặt âm đạo: ${d.misoprostol.vaginal}</div>
      <div class="dosage-item">Uống: ${d.misoprostol.oral}</div>
    </div>
    <div class="dosage-group"><div class="dosage-title">Dinoprostone</div>
      <div class="dosage-item">Gel: ${d.dinoprostone.gel}</div>
      <div class="dosage-item">Insert: ${d.dinoprostone.insert}</div>
    </div>
    <div class="dosage-group"><div class="dosage-title">Khoảng cách an toàn trước Oxytocin</div>
      <div class="dosage-item">Sau rút Dinoprostone insert: ${d.safeIntervals.afterDinoprostoneInsert}</div>
      <div class="dosage-item">Sau Dinoprostone gel: ${d.safeIntervals.afterDinoprostoneGel}</div>
      <div class="dosage-item">Sau Misoprostol uống: ${d.safeIntervals.afterMisoprostolOral}</div>
      <div class="dosage-item">Sau Misoprostol đặt âm đạo: ${d.safeIntervals.afterMisoprostolVaginal}</div>
    </div>`;
        }

        // Copy Prompt
        document
            .getElementById("bs-copy-btn")
            .addEventListener("click", async () => {
                const text =
                    document.getElementById("bs-prompt-output").textContent;
                try {
                    await navigator.clipboard.writeText(text);
                    const btn = document.getElementById("bs-copy-text");
                    btn.textContent = "✅ Đã Copy!";
                    setTimeout(() => {
                        btn.textContent = "Copy Prompt";
                    }, 2000);
                } catch {
                    const ta = document.createElement("textarea");
                    ta.value = text;
                    document.body.appendChild(ta);
                    ta.select();
                    document.execCommand("copy");
                    document.body.removeChild(ta);
                    const btn = document.getElementById("bs-copy-text");
                    btn.textContent = "✅ Đã Copy!";
                    setTimeout(() => {
                        btn.textContent = "Copy Prompt";
                    }, 2000);
                }
            });

        // Print
        document
            .getElementById("bs-print-btn")
            .addEventListener("click", () => window.print());

        function showError(msg) {
            errorEl.textContent = msg;
            errorEl.hidden = false;
        }
        function hideError() {
            errorEl.hidden = true;
        }
    </script>
</BaseLayout>
