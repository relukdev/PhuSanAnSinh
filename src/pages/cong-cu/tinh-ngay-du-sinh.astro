---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";
---

<BaseLayout
    title="Tính Ngày Dự Sinh Chính Xác — ACOG 700 | Phòng Khám An Sinh"
    description="Công cụ tính ngày dự sinh theo Naegele, IVF/ART, siêu âm CRL. Tuân thủ ACOG Committee Opinion 700. Miễn phí, dựa trên khoa học y khoa."
>
    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "FAQPage",
            mainEntity: [
                {
                    "@type": "Question",
                    name: "Tính ngày dự sinh như thế nào?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Ngày dự sinh được tính theo quy tắc Naegele: ngày đầu kỳ kinh cuối + 280 ngày (40 tuần). Với chu kỳ không phải 28 ngày, công thức được hiệu chỉnh: LMP + 280 + (độ dài chu kỳ − 28) ngày, theo ACOG Committee Opinion No. 700.",
                    },
                },
                {
                    "@type": "Question",
                    name: "Ngày dự sinh có chính xác 100% không?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Chỉ khoảng 4-5% phụ nữ sinh đúng ngày dự sinh. Phần lớn sinh trong khoảng ±2 tuần. Siêu âm tam cá nguyệt I (đo CRL) cho độ chính xác cao nhất (±5-7 ngày).",
                    },
                },
                {
                    "@type": "Question",
                    name: "IVF thì tính ngày dự sinh thế nào?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Với IVF/thụ tinh ống nghiệm, ngày dự sinh = ngày chuyển phôi + (266 − tuổi phôi) ngày. Phôi ngày 5: +261 ngày, phôi ngày 3: +263 ngày. Theo ACOG-700, thai kỳ ART không cần điều chỉnh bằng siêu âm.",
                    },
                },
            ],
        })}
    ></script>

    <!-- Hero -->
    <section class="hero tool-hero" id="hero">
        <div class="container">
            <div class="tool-hero-content">
                <span class="section-label">Công cụ miễn phí</span>
                <h1>
                    Tính Ngày Dự Sinh<br />
                    <span class="text-accent-color">Chính Xác</span>
                </h1>
                <p class="hero-sub">
                    Dựa trên quy tắc Naegele & ACOG Committee Opinion No. 700.
                    Hỗ trợ tính theo ngày kinh cuối, IVF, hoặc siêu âm CRL.
                </p>
            </div>
        </div>
    </section>

    <!-- Calculator -->
    <section class="section" id="calculator">
        <div class="container">
            <div class="calc-layout">
                <div class="calc-form-panel">
                    <div class="card calc-card">
                        <h2 class="calc-title">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="M8 14s1.5 2 4 2 4-2 4-2"></path><line x1="9" y1="9" x2="9.01" y2="9"></line><line x1="15" y1="9" x2="15.01" y2="9"></line></svg>
                            Nhập thông tin thai kỳ
                        </h2>

                        <form id="due-date-form" novalidate>
                            <!-- Method selector -->
                            <div class="form-group">
                                <label class="form-label">Phương pháp tính</label>
                                <div class="method-chips" id="method-chips">
                                    <button type="button" class="method-chip is-active" data-method="lmp">📅 Ngày kinh cuối</button>
                                    <button type="button" class="method-chip" data-method="ivf">🧬 IVF / ART</button>
                                    <button type="button" class="method-chip" data-method="us">📷 Siêu âm CRL</button>
                                </div>
                            </div>

                            <!-- LMP fields -->
                            <div id="fields-lmp">
                                <div class="form-group">
                                    <label for="lmp-date" class="form-label">Ngày đầu tiên kỳ kinh cuối</label>
                                    <input type="date" id="lmp-date" class="form-input" required aria-describedby="lmp-help" />
                                    <small id="lmp-help" class="form-help">Ngày đầu tiên bạn thấy kinh nguyệt</small>
                                </div>
                                <div class="form-group">
                                    <label for="cycle-length" class="form-label">
                                        Độ dài chu kỳ: <strong id="cycle-value">28</strong> ngày
                                    </label>
                                    <input type="range" id="cycle-length" min="21" max="40" value="28" class="form-range" />
                                    <div class="range-labels"><span>21</span><span>28</span><span>40</span></div>
                                    <small class="form-help">Trung bình 28 ngày. Nếu không rõ, giữ nguyên giá trị mặc định.</small>
                                </div>
                            </div>

                            <!-- IVF fields -->
                            <div id="fields-ivf" hidden>
                                <div class="form-group">
                                    <label for="ivf-date" class="form-label">Ngày chuyển phôi</label>
                                    <input type="date" id="ivf-date" class="form-input" />
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Tuổi phôi khi chuyển</label>
                                    <div class="embryo-chips" id="embryo-chips">
                                        <button type="button" class="embryo-chip" data-day="3">Ngày 3</button>
                                        <button type="button" class="embryo-chip is-active" data-day="5">Ngày 5</button>
                                        <button type="button" class="embryo-chip" data-day="6">Ngày 6</button>
                                    </div>
                                </div>
                            </div>

                            <!-- Ultrasound CRL fields -->
                            <div id="fields-us" hidden>
                                <div class="form-group">
                                    <label for="us-date" class="form-label">Ngày siêu âm</label>
                                    <input type="date" id="us-date" class="form-input" />
                                </div>
                                <div class="form-group">
                                    <label for="crl-mm" class="form-label">CRL — Chiều dài đầu mông (mm)</label>
                                    <input type="number" id="crl-mm" class="form-input" placeholder="vd: 45" min="10" max="84" step="1" inputmode="numeric" />
                                    <small class="form-help">Giá trị hợp lệ: 10–84 mm (khoảng 7–14 tuần)</small>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-accent btn-lg calc-submit" id="calc-submit">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
                                Tính Ngày Dự Sinh
                            </button>

                            <div id="form-error" class="form-error" role="alert" aria-live="polite" hidden></div>
                        </form>
                    </div>

                    <div class="edu-note">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--info)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                        <p>
                            Dựa trên <strong>ACOG Committee Opinion No. 700 (2017)</strong>.
                            Kết quả là <strong>ước tính</strong>, không thay thế tư vấn y khoa.
                        </p>
                    </div>
                </div>

                <!-- Results -->
                <div class="calc-results-panel" id="results-panel" hidden>
                    <!-- EDD Result -->
                    <div class="results-cards">
                        <div class="result-card result-edd">
                            <div class="result-icon" aria-hidden="true">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M8 14s1.5 2 4 2 4-2 4-2"></path><line x1="9" y1="9" x2="9.01" y2="9"></line><line x1="15" y1="9" x2="15.01" y2="9"></line></svg>
                            </div>
                            <div class="result-info">
                                <span class="result-label">Ngày dự sinh</span>
                                <strong class="result-date" id="result-edd">—</strong>
                            </div>
                        </div>
                        <div class="result-card result-ga">
                            <div class="result-icon" aria-hidden="true">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                            </div>
                            <div class="result-info">
                                <span class="result-label">Tuổi thai hiện tại</span>
                                <strong class="result-date" id="result-ga">—</strong>
                            </div>
                        </div>
                        <div class="result-card result-trimester">
                            <div class="result-icon" aria-hidden="true">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                            </div>
                            <div class="result-info">
                                <span class="result-label">Tam cá nguyệt</span>
                                <strong class="result-date" id="result-trimester">—</strong>
                            </div>
                        </div>
                    </div>

                    <!-- Progress Bar -->
                    <div class="card progress-card">
                        <h3 class="progress-title">Tiến trình thai kỳ</h3>
                        <div class="progress-bar-wrap">
                            <div class="progress-track">
                                <div class="progress-fill" id="progress-fill"></div>
                            </div>
                            <div class="progress-labels">
                                <span>0 tuần</span>
                                <span id="progress-text">0%</span>
                                <span>40 tuần</span>
                            </div>
                        </div>
                        <div class="baby-dev" id="baby-dev" hidden>
                            <span class="baby-emoji" id="baby-emoji"></span>
                            <div>
                                <strong id="baby-fruit"></strong>
                                <p id="baby-desc"></p>
                                <div class="baby-stats">
                                    <span id="baby-size"></span>
                                    <span id="baby-weight"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Milestones -->
                    <div class="card milestones-card">
                        <h3 class="milestones-title">Lịch khám thai theo chuẩn Bộ Y Tế</h3>
                        <div class="milestones-list" id="milestones-list"></div>
                    </div>

                    <!-- Warnings -->
                    <div id="warnings-container"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="section section-alt" id="faq">
        <div class="container">
            <div class="section-header">
                <span class="section-label">Câu hỏi thường gặp</span>
                <h2>Hiểu rõ hơn về ngày dự sinh</h2>
            </div>
            <div class="faq-list">
                <details class="faq-item">
                    <summary class="faq-question">Ngày dự sinh được tính theo công thức nào?</summary>
                    <div class="faq-answer">
                        <p>
                            Công thức Naegele (1838): <strong>Ngày dự sinh = LMP + 280 ngày</strong> (40 tuần).
                            Với chu kỳ không phải 28 ngày, ACOG-700 khuyến cáo hiệu chỉnh:
                            EDD = LMP + 280 + (chu kỳ − 28) ngày. Ví dụ: chu kỳ 30 ngày thì +282 ngày.
                        </p>
                    </div>
                </details>
                <details class="faq-item">
                    <summary class="faq-question">Bao nhiêu phụ nữ sinh đúng ngày dự sinh?</summary>
                    <div class="faq-answer">
                        <p>
                            Chỉ khoảng <strong>4-5%</strong> phụ nữ sinh đúng ngày dự sinh.
                            Khoảng 80% sinh trong khoảng ±2 tuần (38-42 tuần). Thai kỳ đủ tháng
                            là từ 39+0 đến 40+6 tuần (ACOG Committee Opinion No. 579).
                        </p>
                    </div>
                </details>
                <details class="faq-item">
                    <summary class="faq-question">Tại sao siêu âm CRL cho kết quả chính xác hơn?</summary>
                    <div class="faq-answer">
                        <p>
                            CRL (chiều dài đầu mông) đo trong tam cá nguyệt I (7-14 tuần) có sai số
                            chỉ <strong>±5-7 ngày</strong>, vì thai nhi ở giai đoạn sớm phát triển
                            rất đồng đều giữa các cá thể. Càng về sau, biến thiên càng lớn
                            (sai số ±21 ngày ở tam cá nguyệt III).
                        </p>
                    </div>
                </details>
                <details class="faq-item">
                    <summary class="faq-question">IVF tính ngày dự sinh khác gì?</summary>
                    <div class="faq-answer">
                        <p>
                            Với IVF/ART, ngày thụ thai đã biết chính xác nên công thức là:
                            <strong>EDD = ngày chuyển phôi + (266 − tuổi phôi)</strong>.
                            Phôi ngày 5 (blastocyst): +261 ngày, phôi ngày 3: +263 ngày.
                            Theo ACOG-700, thai kỳ ART <em>không cần</em> điều chỉnh bằng siêu âm.
                        </p>
                    </div>
                </details>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section cta-section" id="cta">
        <div class="container">
            <div class="cta-content">
                <h2>Cần tư vấn thêm về thai kỳ?</h2>
                <p>
                    Bác sĩ sản khoa 20+ năm kinh nghiệm tại An Sinh
                    sẵn sàng đồng hành cùng bạn suốt thai kỳ.
                </p>
                <div class="cta-actions">
                    <button type="button" class="btn btn-accent btn-lg open-booking" data-form-type="kham-thai">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                        Đặt Lịch Khám Thai
                    </button>
                    <a href="tel:0899268299" class="btn btn-outline btn-lg">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"></path></svg>
                        Gọi: 0899 268 299
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Disclaimer -->
    <section class="disclaimer-section">
        <div class="container">
            <p class="disclaimer-text">
                <strong>Lưu ý y khoa:</strong> Công cụ này cung cấp kết quả <em>ước tính</em>
                dựa trên ACOG Committee Opinion No. 700 (2017, Reaffirmed 2022).
                Kết quả không thay thế tư vấn y khoa chuyên nghiệp.
                Vui lòng liên hệ bác sĩ chuyên khoa để được tư vấn chính xác.
            </p>
        </div>
    </section>

    <style>
        .tool-hero { background: linear-gradient(135deg, var(--primary-light) 0%, var(--bg) 100%); padding: var(--space-4xl) 0 var(--space-3xl); text-align: center; }
        .tool-hero-content { max-width: 700px; margin: 0 auto; }
        .tool-hero h1 { margin-bottom: var(--space-lg); }
        .hero-sub { font-size: 1.125rem; color: var(--text-secondary); line-height: 1.8; max-width: 600px; margin: 0 auto; }
        .calc-layout { display: grid; grid-template-columns: 1fr; gap: var(--space-2xl); max-width: 700px; margin: 0 auto; }
        .calc-card { position: static; }
        .calc-title { display: flex; align-items: center; gap: var(--space-sm); font-size: 1.25rem; margin-bottom: var(--space-xl); }
        .form-group { margin-bottom: var(--space-xl); }
        .form-label { display: block; font-weight: 600; font-size: 0.9375rem; margin-bottom: var(--space-sm); color: var(--text-primary); }
        .form-input { width: 100%; padding: 0.875rem 1rem; border: 2px solid var(--border); border-radius: var(--radius-md); font-family: var(--font-body); font-size: 1rem; color: var(--text-primary); background: var(--bg-white); transition: border-color var(--transition-fast); min-height: 44px; box-sizing: border-box; }
        .form-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(27,122,109,.1); }
        .form-range { width: 100%; height: 8px; appearance: none; -webkit-appearance: none; background: var(--border); border-radius: var(--radius-full); outline: none; margin: var(--space-sm) 0; }
        .form-range::-webkit-slider-thumb { appearance: none; -webkit-appearance: none; width: 28px; height: 28px; border-radius: 50%; background: var(--primary); cursor: pointer; border: 3px solid #fff; box-shadow: var(--shadow-md); }
        .form-range::-moz-range-thumb { width: 28px; height: 28px; border-radius: 50%; background: var(--primary); cursor: pointer; border: 3px solid #fff; box-shadow: var(--shadow-md); }
        .range-labels { display: flex; justify-content: space-between; font-size: .75rem; color: var(--text-muted); }
        .form-help { display: block; font-size: .8125rem; color: var(--text-muted); margin-top: var(--space-xs); }
        .calc-submit { width: 100%; }
        .form-error { margin-top: var(--space-md); padding: var(--space-sm) var(--space-md); background: #fef2f2; border: 1px solid #fca5a5; border-radius: var(--radius-md); color: var(--error); font-size: .875rem; }
        .edu-note { display: flex; gap: var(--space-sm); padding: var(--space-md); background: #eff6ff; border-radius: var(--radius-md); border-left: 3px solid var(--info); margin-top: var(--space-lg); }
        .edu-note svg { flex-shrink: 0; margin-top: 2px; }
        .edu-note p { font-size: .8125rem; color: var(--text-secondary); margin: 0; line-height: 1.6; }

        /* Method chips */
        .method-chips, .embryo-chips { display: flex; gap: var(--space-sm); flex-wrap: wrap; }
        .method-chip, .embryo-chip { padding: .625rem 1rem; border-radius: var(--radius-full); border: 1.5px solid var(--border); background: var(--surface); font-size: .875rem; font-weight: 500; cursor: pointer; transition: all var(--transition-fast); color: var(--text-secondary); font-family: var(--font-body); min-height: 44px; }
        .method-chip:hover, .embryo-chip:hover { border-color: var(--primary); color: var(--primary); }
        .method-chip.is-active, .embryo-chip.is-active { background: var(--primary); color: #fff; border-color: var(--primary); }

        /* Results */
        .results-cards { display: grid; grid-template-columns: 1fr; gap: var(--space-md); margin-bottom: var(--space-xl); }
        .result-card { display: flex; align-items: center; gap: var(--space-lg); padding: var(--space-lg); border-radius: var(--radius-lg); border: 1px solid var(--border-light); background: var(--surface); transition: all var(--transition-base); }
        .result-card:hover { box-shadow: var(--shadow-md); }
        .result-icon { display: flex; align-items: center; justify-content: center; width: 56px; height: 56px; border-radius: var(--radius-md); flex-shrink: 0; }
        .result-edd .result-icon { background: #fff7ed; color: var(--accent); }
        .result-ga .result-icon { background: var(--primary-light); color: var(--primary); }
        .result-trimester .result-icon { background: #f0fdf4; color: var(--success); }
        .result-label { display: block; font-size: .8125rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: .04em; font-weight: 500; }
        .result-date { display: block; font-size: 1.25rem; color: var(--text-primary); margin-top: 2px; }

        /* Progress */
        .progress-title, .milestones-title { font-size: 1.125rem; margin-bottom: var(--space-lg); }
        .progress-track { width: 100%; height: 12px; background: var(--border); border-radius: var(--radius-full); overflow: hidden; }
        .progress-fill { height: 100%; background: linear-gradient(90deg, var(--primary), var(--accent)); border-radius: var(--radius-full); transition: width .6s ease; width: 0; }
        .progress-labels { display: flex; justify-content: space-between; font-size: .75rem; color: var(--text-muted); margin-top: var(--space-xs); }
        .baby-dev { display: flex; gap: var(--space-md); align-items: flex-start; margin-top: var(--space-lg); padding: var(--space-lg); background: var(--surface-alt); border-radius: var(--radius-md); }
        .baby-emoji { font-size: 2.5rem; line-height: 1; flex-shrink: 0; }
        .baby-dev strong { display: block; font-size: .9375rem; margin-bottom: 4px; }
        .baby-dev p { font-size: .8125rem; color: var(--text-secondary); margin: 0 0 var(--space-sm); line-height: 1.6; }
        .baby-stats { display: flex; gap: var(--space-lg); font-size: .8125rem; color: var(--text-muted); }

        /* Milestones */
        .milestones-list { display: flex; flex-direction: column; gap: var(--space-md); }
        .milestone-item { display: flex; gap: var(--space-md); padding: var(--space-md); border-radius: var(--radius-md); border: 1px solid var(--border-light); transition: all var(--transition-fast); }
        .milestone-item:hover { box-shadow: var(--shadow-sm); }
        .milestone-item.is-past { opacity: .5; }
        .milestone-item.is-current { border-color: var(--primary); background: var(--primary-light); }
        .milestone-dot { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; background: var(--surface-alt); }
        .milestone-item.is-past .milestone-dot { background: var(--border); }
        .milestone-item.is-current .milestone-dot { background: var(--primary); color: #fff; }
        .milestone-info { flex: 1; }
        .milestone-week { font-size: .75rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: .04em; }
        .milestone-name { font-weight: 600; font-size: .9375rem; margin: 2px 0; }
        .milestone-desc { font-size: .8125rem; color: var(--text-secondary); margin: 0; line-height: 1.5; }
        .milestone-tests { display: flex; flex-wrap: wrap; gap: 4px; margin-top: var(--space-xs); }
        .milestone-tag { font-size: .6875rem; background: var(--surface-alt); padding: 2px 8px; border-radius: var(--radius-full); color: var(--text-muted); }

        /* Warnings */
        .warning-card { padding: var(--space-md); border-radius: var(--radius-md); margin-bottom: var(--space-md); display: flex; gap: var(--space-sm); align-items: flex-start; }
        .warning-card.severity-info { background: #eff6ff; border: 1px solid #93c5fd; }
        .warning-card.severity-warning { background: #fffbeb; border: 1px solid #fbbf24; }
        .warning-card.severity-danger { background: #fef2f2; border: 1px solid #fca5a5; }
        .warning-card p { font-size: .875rem; margin: 0; line-height: 1.6; }

        @media (max-width: 640px) {
            .method-chips { flex-direction: column; }
            .method-chip { text-align: center; }
        }
    </style>

    <script>
        import {
            toLocalDate, calculateDueDate, calculateGestationalAge, getTrimester,
            getPregnancyProgress, generateCheckupMilestones, getBabyDevelopment,
            getMilestoneStatus, formatDateVN, validateLmpDate,
            calcEddByLmpModified, calcEddByIvf, calcGaFromCrl, calcEddFromUltrasoundGa,
            getTermClassification, getClinicalWarnings
        } from '../../utils/due-date-calc.js';

        let currentMethod = 'lmp';
        let selectedEmbryoDay = 5;

        // Method switching
        document.getElementById('method-chips')?.addEventListener('click', (e) => {
            const chip = e.target.closest('.method-chip');
            if (!chip) return;
            document.querySelectorAll('.method-chip').forEach(c => c.classList.remove('is-active'));
            chip.classList.add('is-active');
            currentMethod = chip.dataset.method;
            document.getElementById('fields-lmp').hidden = currentMethod !== 'lmp';
            document.getElementById('fields-ivf').hidden = currentMethod !== 'ivf';
            document.getElementById('fields-us').hidden = currentMethod !== 'us';
        });

        // Embryo day chips
        document.getElementById('embryo-chips')?.addEventListener('click', (e) => {
            const chip = e.target.closest('.embryo-chip');
            if (!chip) return;
            document.querySelectorAll('.embryo-chip').forEach(c => c.classList.remove('is-active'));
            chip.classList.add('is-active');
            selectedEmbryoDay = parseInt(chip.dataset.day);
        });

        // Cycle length slider
        const cycleSlider = document.getElementById('cycle-length');
        const cycleValue = document.getElementById('cycle-value');
        cycleSlider?.addEventListener('input', () => {
            if (cycleValue) cycleValue.textContent = cycleSlider.value;
        });

        // Form submit
        document.getElementById('due-date-form')?.addEventListener('submit', (e) => {
            e.preventDefault();
            const errorEl = document.getElementById('form-error');

            try {
                let edd, lmpForGa;

                if (currentMethod === 'lmp') {
                    const lmpDate = document.getElementById('lmp-date').value;
                    const cycleLength = parseInt(cycleSlider?.value || '28');
                    if (!lmpDate) throw new Error('Vui lòng nhập ngày kinh cuối.');
                    const validation = validateLmpDate(lmpDate);
                    if (!validation.valid) throw new Error(validation.error);
                    edd = calcEddByLmpModified(lmpDate, cycleLength);
                    lmpForGa = toLocalDate(lmpDate);

                } else if (currentMethod === 'ivf') {
                    const ivfDate = document.getElementById('ivf-date').value;
                    if (!ivfDate) throw new Error('Vui lòng nhập ngày chuyển phôi.');
                    edd = calcEddByIvf(ivfDate, selectedEmbryoDay);
                    // Convert to equivalent LMP for GA calculation
                    const eddDate = toLocalDate(edd);
                    lmpForGa = new Date(eddDate);
                    lmpForGa.setDate(lmpForGa.getDate() - 280);

                } else if (currentMethod === 'us') {
                    const usDate = document.getElementById('us-date').value;
                    const crl = parseFloat(document.getElementById('crl-mm').value);
                    if (!usDate) throw new Error('Vui lòng nhập ngày siêu âm.');
                    if (isNaN(crl) || crl < 10 || crl > 84) throw new Error('CRL phải từ 10–84 mm.');
                    const gaFromCrl = calcGaFromCrl(crl);
                    edd = calcEddFromUltrasoundGa(usDate, gaFromCrl);
                    lmpForGa = new Date(edd);
                    lmpForGa.setDate(lmpForGa.getDate() - 280);
                }

                // Calculate results
                const ga = calculateGestationalAge(lmpForGa);
                const trimester = getTrimester(ga.weeks);
                const progress = getPregnancyProgress(lmpForGa);
                const babyDev = getBabyDevelopment(ga.weeks);
                const milestones = generateCheckupMilestones(lmpForGa);
                const termClass = getTermClassification(ga.weeks, ga.days);
                const warnings = getClinicalWarnings(ga);

                // Render results
                displayResults(edd, ga, trimester, progress, babyDev, milestones, termClass, warnings);

                // Hide error
                if (errorEl) { errorEl.hidden = true; }
            } catch (err) {
                if (errorEl) {
                    errorEl.textContent = err.message;
                    errorEl.hidden = false;
                }
            }
        });

        function displayResults(edd, ga, trimester, progress, babyDev, milestones, termClass, warnings) {
            const resultsPanel = document.getElementById('results-panel');
            if (resultsPanel) resultsPanel.hidden = false;

            // EDD
            document.getElementById('result-edd').textContent = formatDateVN(edd);

            // GA
            document.getElementById('result-ga').textContent = `${ga.weeks} tuần ${ga.days} ngày`;

            // Trimester
            const TRIMESTER_LABELS = { 1: 'Tam cá nguyệt I (0-13 tuần)', 2: 'Tam cá nguyệt II (14-27 tuần)', 3: 'Tam cá nguyệt III (28+ tuần)' };
            document.getElementById('result-trimester').textContent = TRIMESTER_LABELS[trimester];

            // Progress
            const progressFill = document.getElementById('progress-fill');
            const progressText = document.getElementById('progress-text');
            if (progressFill) progressFill.style.width = `${progress}%`;
            if (progressText) progressText.textContent = `${progress}%`;

            // Baby development
            const babyDevEl = document.getElementById('baby-dev');
            if (babyDev && babyDevEl) {
                babyDevEl.hidden = false;
                document.getElementById('baby-emoji').textContent = babyDev.fruitEmoji;
                document.getElementById('baby-fruit').textContent = `Bé như ${babyDev.fruit}`;
                document.getElementById('baby-desc').textContent = babyDev.description;
                document.getElementById('baby-size').textContent = `📏 ${babyDev.size}`;
                document.getElementById('baby-weight').textContent = `⚖️ ${babyDev.weight}`;
            } else if (babyDevEl) {
                babyDevEl.hidden = true;
            }

            // Milestones
            const ICONS_MAP = {
                stethoscope: '🩺', baby: '👶', clipboard: '📋', scan: '📷',
                droplet: '💉', syringe: '💉', activity: '📊', heart: '❤️',
                'calendar-check': '📅', star: '⭐'
            };
            const milestonesEl = document.getElementById('milestones-list');
            if (milestonesEl) {
                milestonesEl.innerHTML = milestones.map(m => {
                    const status = getMilestoneStatus(m.week, ga.weeks, ga.days);
                    const statusClass = status === 'past' ? 'is-past' : status === 'current' ? 'is-current' : '';
                    const icon = ICONS_MAP[m.icon] || '📌';
                    return `
                        <div class="milestone-item ${statusClass}">
                            <div class="milestone-dot">${icon}</div>
                            <div class="milestone-info">
                                <span class="milestone-week">Tuần ${m.week} — ${formatDateVN(m.date)}</span>
                                <div class="milestone-name">${m.title}</div>
                                <p class="milestone-desc">${m.description}</p>
                                <div class="milestone-tests">
                                    ${m.tests.map(t => `<span class="milestone-tag">${t}</span>`).join('')}
                                </div>
                            </div>
                        </div>
                    `;
                }).join('');
            }

            // Warnings
            const warningsEl = document.getElementById('warnings-container');
            if (warningsEl) {
                warningsEl.innerHTML = warnings.map(w => `
                    <div class="warning-card severity-${w.severity}">
                        <span>${w.severity === 'danger' ? '🚨' : w.severity === 'warning' ? '⚠️' : 'ℹ️'}</span>
                        <p>${w.message}</p>
                    </div>
                `).join('');
            }

            // Scroll to results
            resultsPanel?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    </script>
</BaseLayout>
