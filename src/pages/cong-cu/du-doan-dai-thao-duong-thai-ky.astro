    <script>
        import {
            calcFmfGDMRisk,
            calcFmfPrevGDM,
            stratifyFmfRisk,
            calcPersonalGDMOutcomes,
            stratifyOutcomesRisk,
            calcIowaGDMRisk,
            stratifyIowaRisk,
            validateFmfInputs,
            validateOutcomesInputs,
            validateIowaInputs,
            buildFmfPrompt,
            buildOutcomesPrompt,
            buildIowaPrompt,
            calcBMI,
        } from "../../utils/gdm-calc.js";

        // ── Tab switching ──
        const tabs = document.querySelectorAll(".model-tab");
        const panels = document.querySelectorAll(".tab-panel");
        tabs.forEach((tab) => {
            tab.addEventListener("click", () => {
                tabs.forEach((t) => {
                    t.classList.remove("active");
                    t.setAttribute("aria-selected", "false");
                });
                panels.forEach((p) => {
                    p.classList.remove("active");
                    p.hidden = true;
                });
                tab.classList.add("active");
                tab.setAttribute("aria-selected", "true");
                const panel = document.getElementById(
                    "panel-" + tab.dataset.tab
                );
                panel.classList.add("active");
                panel.hidden = false;
                document.getElementById("results-panel").hidden = true;
            });
        });

        // ── BMI auto-calc for FMF ──
        const fmfWeight = document.getElementById("fmf-weight");
        const fmfHeight = document.getElementById("fmf-height");
        const fmfBmiDisplay = document.getElementById("fmf-bmi-display");
        function updateFmfBmi() {
            const w = parseFloat(fmfWeight.value),
                h = parseFloat(fmfHeight.value);
            if (w > 0 && h > 0) {
                fmfBmiDisplay.textContent = calcBMI(w, h).toFixed(1) + " kg/m²";
            } else {
                fmfBmiDisplay.textContent = "--";
            }
        }
        fmfWeight.addEventListener("input", updateFmfBmi);
        fmfHeight.addEventListener("input", updateFmfBmi);

        // ── Show/hide birth weight z-score ──
        const fmfObsHistory = document.getElementById("fmf-obs-history");
        fmfObsHistory.addEventListener("change", () => {
            document.getElementById("fmf-bw-group").hidden =
                fmfObsHistory.value !== "parous_no_gdm";
        });

        // ── Threshold tables ──
        const FMF_THRESHOLD = `<table class="threshold-table"><thead><tr><th>Nguy cơ</th><th>Phân loại</th><th>Hành động</th></tr></thead><tbody>
<tr><td>&lt; 5%</td><td class="risk-vlow">Thấp</td><td>Sàng lọc thường quy 24-28 tuần</td></tr>
<tr><td>5–15%</td><td class="risk-low">Trung bình</td><td>Cân nhắc sàng lọc sớm + tư vấn lối sống</td></tr>
<tr><td>15–30%</td><td class="risk-high">Cao</td><td>OGTT sớm (16-18 tuần) + can thiệp tích cực</td></tr>
<tr><td>&gt; 30%</td><td class="risk-vhigh">Rất cao</td><td>OGTT sớm + theo dõi sát + metformin</td></tr></tbody></table>`;

        const OUTCOMES_THRESHOLD = `<table class="threshold-table"><thead><tr><th>Nguy cơ</th><th>Phân loại</th><th>Khuyến cáo</th></tr></thead><tbody>
<tr><td>&lt; 15%</td><td class="risk-vlow">Thấp</td><td>Quản lý thường quy, theo dõi cộng đồng</td></tr>
<tr><td>15–30%</td><td class="risk-low">Trung bình</td><td>Theo dõi tiêu chuẩn GDM tại bệnh viện</td></tr>
<tr><td>30–50%</td><td class="risk-high">Cao</td><td>Siêu âm tăng trưởng, khám đa chuyên khoa</td></tr>
<tr><td>&gt; 50%</td><td class="risk-vhigh">Rất cao</td><td>Insulin sớm, NST hàng tuần từ 32 tuần</td></tr></tbody></table>`;

        const IOWA_THRESHOLD = `<table class="threshold-table"><thead><tr><th>Nguy cơ</th><th>Phân loại</th><th>Hành động</th></tr></thead><tbody>
<tr><td>&lt; 6%</td><td class="risk-vlow">Dưới ngưỡng</td><td>Sàng lọc thường quy 24-28 tuần</td></tr>
<tr><td>6–10%</td><td class="risk-low">Trên ngưỡng</td><td>Cân nhắc sàng lọc sớm + lối sống</td></tr>
<tr><td>10–20%</td><td class="risk-high">Cao</td><td>OGTT sớm + tư vấn dinh dưỡng chuyên biệt</td></tr>
<tr><td>&gt; 20%</td><td class="risk-vhigh">Rất cao</td><td>OGTT sớm, can thiệp lối sống tích cực</td></tr></tbody></table>`;

        // ── Display helpers ──
        function showResults(
            strat,
            riskPercent,
            modelLabel,
            detailHtml,
            thresholdHtml,
            promptText
        ) {
            const panel = document.getElementById("results-panel");
            const header = document.getElementById("risk-header");
            header.className = `result-card result-primary card risk-${strat.color}`;
            document.getElementById("risk-emoji").textContent =
                strat.level === "LOW"
                    ? "✅"
                    : strat.level === "MODERATE"
                    ? "🟠"
                    : strat.level === "HIGH"
                    ? "🔴"
                    : strat.level === "VERY_HIGH"
                    ? "🚨"
                    : "✅";
            document.getElementById("result-model-label").textContent =
                modelLabel;
            document.getElementById("risk-level").textContent = strat.label;
            document.getElementById("risk-action").textContent = strat.action;
            document.getElementById("risk-detail-content").innerHTML =
                detailHtml;
            document.getElementById("threshold-table-wrap").innerHTML =
                thresholdHtml;
            document.getElementById("prompt-output").textContent = promptText;
            panel.hidden = false;
            panel.scrollIntoView({ behavior: "smooth", block: "start" });
        }

        function statBox(label, value, cls = "") {
            return `<div class="risk-stat"><div class="risk-stat-label">${label}</div><div class="risk-stat-value ${cls}">${value}</div></div>`;
        }

        function showError(id, msg) {
            const el = document.getElementById(id);
            el.textContent = msg;
            el.hidden = false;
        }
        function hideError(id) {
            document.getElementById(id).hidden = true;
        }

        // ── A: FMF Form ──
        document.getElementById("fmf-form").addEventListener("submit", (e) => {
            e.preventDefault();
            hideError("fmf-error");
            const fd = {
                age: parseFloat(document.getElementById("fmf-age").value),
                weight: parseFloat(document.getElementById("fmf-weight").value),
                height: parseFloat(document.getElementById("fmf-height").value),
                ethnicity: document.getElementById("fmf-ethnicity").value,
                conception: document.getElementById("fmf-conception").value,
                familyDM: document.getElementById("fmf-family-dm").value,
                obsHistory: fmfObsHistory.value,
                birthWeightZscore:
                    parseFloat(
                        document.getElementById("fmf-bw-zscore").value
                    ) || 0,
                smoking:
                    document.querySelector('input[name="fmf-smoking"]:checked')
                        ?.value === "yes",
            };
            const v = validateFmfInputs(fd);
            if (!v.valid) return showError("fmf-error", v.error);

            let result, riskPct;
            if (fd.obsHistory === "parous_prev_gdm") {
                const risk = calcFmfPrevGDM(fd.weight);
                result = {
                    logOdds: -4.005 + 0.0206 * (fd.weight - 69),
                    risk,
                    contributions: {},
                };
                riskPct = risk * 100;
            } else {
                result = calcFmfGDMRisk(fd);
                riskPct = result.risk * 100;
            }
            const bmi = calcBMI(fd.weight, fd.height);
            fd.bmi = bmi.toFixed(1);
            const strat = stratifyFmfRisk(riskPct);
            const detail = `<div class="risk-detail-grid">${statBox(
                "Log-odds",
                result.logOdds.toFixed(4)
            )}${statBox(
                "Nguy cơ GDM",
                riskPct.toFixed(1) + "%",
                riskPct >= 15 ? "val-risk" : "val-ok"
            )}${statBox("BMI", bmi.toFixed(1))}${statBox(
                "AUROC mô hình",
                "0.823"
            )}</div>`;
            showResults(
                strat,
                riskPct,
                "FMF GDM Risk (Syngelaki 2014)",
                detail,
                FMF_THRESHOLD,
                buildFmfPrompt(fd, result)
            );
        });

        // ── B: Outcomes Form ──
        document
            .getElementById("outcomes-form")
            .addEventListener("submit", (e) => {
                e.preventDefault();
                hideError("out-error");
                const gaAtDiag = parseFloat(
                    document.getElementById("out-ga-diag").value
                );
                const totalGain = parseFloat(
                    document.getElementById("out-weight-gain").value
                );
                const fd = {
                    age: parseFloat(document.getElementById("out-age").value),
                    bmi: parseFloat(document.getElementById("out-bmi").value),
                    ethnicity: document.getElementById("out-ethnicity").value,
                    fastingGlucose: parseFloat(
                        document.getElementById("out-fasting").value
                    ),
                    glucose1h: parseFloat(
                        document.getElementById("out-1h").value
                    ),
                    gaAtDiagnosis: gaAtDiag,
                    weightGainPerWeek: gaAtDiag > 0 ? totalGain / gaAtDiag : 0,
                    nulliparous:
                        document.getElementById("out-nulliparous").checked,
                    prevLGA: document.getElementById("out-prev-lga").checked,
                    prevPreeclampsia:
                        document.getElementById("out-prev-pe").checked,
                    familyDM: document.getElementById("out-family-dm").checked,
                };
                const v = validateOutcomesInputs(fd);
                if (!v.valid) return showError("out-error", v.error);

                const result = calcPersonalGDMOutcomes(fd);
                const riskPct = result.risk * 100;
                const strat = stratifyOutcomesRisk(riskPct);
                const detail = `<div class="risk-detail-grid">${statBox(
                    "Y (log-odds)",
                    result.Y.toFixed(4)
                )}${statBox(
                    "Nguy cơ biến cố",
                    riskPct.toFixed(1) + "%",
                    riskPct >= 30 ? "val-risk" : "val-ok"
                )}${statBox(
                    "Tăng cân/tuần",
                    fd.weightGainPerWeek.toFixed(2) + " kg"
                )}${statBox("AUROC mô hình", "0.68")}</div>`;
                showResults(
                    strat,
                    riskPct,
                    "PersonalGDM Outcomes (Monash 2022)",
                    detail,
                    OUTCOMES_THRESHOLD,
                    buildOutcomesPrompt(fd, result)
                );
            });

        // ── C: Iowa Form ──
        document.getElementById("iowa-form").addEventListener("submit", (e) => {
            e.preventDefault();
            hideError("iowa-error");
            const fd = {
                ethnicity: document.getElementById("iowa-ethnicity").value,
                age: parseFloat(document.getElementById("iowa-age").value),
                bmi: parseFloat(document.getElementById("iowa-bmi").value),
                familyDM:
                    document.querySelector(
                        'input[name="iowa-family-dm"]:checked'
                    )?.value === "yes",
                preexistingHTN:
                    document.querySelector('input[name="iowa-htn"]:checked')
                        ?.value === "yes",
            };
            const v = validateIowaInputs(fd);
            if (!v.valid) return showError("iowa-error", v.error);

            const result = calcIowaGDMRisk(fd);
            const riskPct = result.risk * 100;
            const strat = stratifyIowaRisk(riskPct);
            const detail = `<div class="risk-detail-grid">${statBox(
                "t (log-odds)",
                result.t.toFixed(4)
            )}${statBox(
                "Nguy cơ GDM",
                riskPct.toFixed(1) + "%",
                riskPct >= 6 ? "val-risk" : "val-ok"
            )}${statBox("Ngưỡng cao", "≥ 6%")}${statBox(
                "AUC (Asian)",
                "0.665"
            )}</div>`;
            showResults(
                strat,
                riskPct,
                "Iowa Nulliparous (Donovan 2019)",
                detail,
                IOWA_THRESHOLD,
                buildIowaPrompt(fd, result)
            );
        });

        // ── Copy Prompt ──
        document
            .getElementById("copy-prompt-btn")
            .addEventListener("click", async () => {
                const text =
                    document.getElementById("prompt-output").textContent;
                try {
                    await navigator.clipboard.writeText(text);
                } catch {
                    const ta = document.createElement("textarea");
                    ta.value = text;
                    document.body.appendChild(ta);
                    ta.select();
                    document.execCommand("copy");
                    document.body.removeChild(ta);
                }
                const btn = document.getElementById("copy-btn-text");
                btn.textContent = "✅ Đã Copy!";
                setTimeout(() => {
                    btn.textContent = "Copy Prompt";
                }, 2000);
            });
    </script>
</BaseLayout>
