---
import "../../styles/global.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
const title =
    "Dự Đoán Nguy Cơ Đái Tháo Đường Thai Kỳ (GDM) — FMF + PersonalGDM + Iowa | An Sinh";
const description =
    "Công cụ tính nguy cơ đái tháo đường thai kỳ dựa trên 3 mô hình: FMF (Syngelaki 2014), PersonalGDM Outcomes (Monash 2022), Iowa Nulliparous (Donovan 2019). Tạo prompt AI cho gợi ý lâm sàng.";
---

<BaseLayout title={title} description={description}>
    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "FAQPage",
            mainEntity: [
                {
                    "@type": "Question",
                    name: "Công cụ dự đoán GDM hoạt động như thế nào?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Công cụ sử dụng 3 mô hình y khoa: FMF (Syngelaki/Nicolaides 2014), PersonalGDM Outcomes (Monash University 2022), và Iowa Nulliparous (Donovan/Ryckman 2019) để ước tính nguy cơ đái tháo đường thai kỳ.",
                    },
                },
                {
                    "@type": "Question",
                    name: "Ai nên sử dụng công cụ này?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Bác sĩ sản khoa sử dụng để hỗ trợ đánh giá nguy cơ GDM cho thai phụ. FMF dùng cho tất cả thai phụ tại tam cá nguyệt I, Iowa chỉ dành cho con so, PersonalGDM Outcomes cho thai phụ đã chẩn đoán GDM.",
                    },
                },
                {
                    "@type": "Question",
                    name: "Đái tháo đường thai kỳ là gì?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "GDM là tình trạng rối loạn dung nạp glucose xuất hiện lần đầu trong thai kỳ. Tỷ lệ mắc khoảng 2-10% tùy dân số. Phụ nữ Đông Á có nguy cơ cao hơn (OR ≈ 2.9).",
                    },
                },
            ],
        })}
    ></script>

    <!-- Hero -->
    <section class="calc-hero">
        <div class="container">
            <div class="hero-badge">
                <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    ><path d="M22 11.08V12a10 10 0 11-5.93-9.14"
                    ></path><polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg> FMF + PersonalGDM + Iowa · Miễn phí 100%
            </div>
            <h1>
                Dự Đoán Nguy Cơ <span class="text-accent-color"
                    >Đái Tháo Đường Thai Kỳ</span>
            </h1>
            <p class="hero-sub">
                Phân tích nguy cơ GDM dựa trên 3 mô hình y khoa quốc tế. Tính
                toán tự động và tạo prompt AI cho gợi ý lâm sàng chi tiết.
            </p>
        </div>
    </section>

    <!-- Calculator -->
    <section class="calc-section">
        <div class="container">
            <div class="calc-grid">
                <!-- Tab Selector -->
                <div class="model-tabs" role="tablist">
                    <button
                        class="model-tab active"
                        role="tab"
                        aria-selected="true"
                        data-tab="fmf"
                        >A. FMF GDM<span class="tab-sub">Tam cá nguyệt I</span>
                    </button>
                    <button
                        class="model-tab"
                        role="tab"
                        aria-selected="false"
                        data-tab="outcomes"
                        >B. PersonalGDM<span class="tab-sub">Đã có GDM</span>
                    </button>
                    <button
                        class="model-tab"
                        role="tab"
                        aria-selected="false"
                        data-tab="iowa"
                        >C. Iowa<span class="tab-sub">Con so</span>
                    </button>
                </div>

                <!-- ═══ TAB A: FMF ═══ -->
                <div class="tab-panel active" id="panel-fmf" role="tabpanel">
                    <div class="calc-input-panel card">
                        <h2 class="calc-panel-title">
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="var(--primary)"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                aria-hidden="true"
                                ><path
                                    d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"
                                ></path><polyline points="14 2 14 8 20 8"
                                ></polyline><line x1="16" y1="13" x2="8" y2="13"
                                ></line><line x1="16" y1="17" x2="8" y2="17"
                                ></line>
                            </svg> FMF GDM Risk Calculator
                        </h2>
                        <form id="fmf-form" novalidate>
                            <div class="form-section-label">Thông tin mẹ</div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="fmf-age" class="form-label"
                                        >Tuổi mẹ</label
                                    ><input
                                        type="number"
                                        id="fmf-age"
                                        class="form-input"
                                        min="14"
                                        max="60"
                                        placeholder="VD: 30"
                                        required
                                    />
                                </div>
                                <div class="form-group">
                                    <label for="fmf-weight" class="form-label"
                                        >Cân nặng (kg)</label
                                    ><input
                                        type="number"
                                        id="fmf-weight"
                                        class="form-input"
                                        min="30"
                                        max="200"
                                        step="0.1"
                                        placeholder="Đo tại 11-13 tuần"
                                        required
                                    />
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="fmf-height" class="form-label"
                                        >Chiều cao (cm)</label
                                    ><input
                                        type="number"
                                        id="fmf-height"
                                        class="form-input"
                                        min="120"
                                        max="220"
                                        step="0.1"
                                        placeholder="VD: 158"
                                        required
                                    />
                                </div>
                                <div class="form-group">
                                    <label class="form-label"
                                        >BMI (tự tính)</label
                                    ><div
                                        class="bmi-display"
                                        id="fmf-bmi-display"
                                    >
                                        --
                                    </div>
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="fmf-ethnicity" class="form-label"
                                    >Chủng tộc</label
                                >
                                <select id="fmf-ethnicity" class="form-input">
                                    <option value="caucasian"
                                        >Da trắng (Caucasian)</option
                                    >
                                    <option value="afro_caribbean"
                                        >Châu Phi/Afro-Caribbean</option
                                    >
                                    <option value="south_asian"
                                        >Nam Á (South Asian)</option
                                    >
                                    <option value="east_asian" selected
                                        >Đông Á (bao gồm Việt Nam)</option
                                    >
                                    <option value="mixed"
                                        >Hỗn hợp (Mixed)</option
                                    >
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="fmf-conception" class="form-label"
                                    >Phương pháp thụ thai</label
                                >
                                <select id="fmf-conception" class="form-input">
                                    <option value="natural">Tự nhiên</option>
                                    <option value="ovulation_drugs"
                                        >Thuốc kích trứng</option
                                    >
                                    <option value="ivf">IVF</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="fmf-family-dm" class="form-label"
                                    >Tiền sử gia đình ĐTĐ</label
                                >
                                <select id="fmf-family-dm" class="form-input">
                                    <option value="none">Không</option>
                                    <option value="degree1"
                                        >Có — Bậc 1 (bố/mẹ/anh chị em)</option
                                    >
                                    <option value="degree2"
                                        >Có — Bậc 2 (ông bà/cô chú)</option
                                    >
                                </select>
                            </div>
                            <hr class="form-divider" />
                            <div class="form-section-label">
                                Tiền sử sản khoa
                            </div>
                            <div class="form-group">
                                <label for="fmf-obs-history" class="form-label"
                                    >Tiền sử sản khoa</label
                                >
                                <select id="fmf-obs-history" class="form-input">
                                    <option value="nulliparous"
                                        >Con so (chưa sinh lần nào ≥24 tuần)</option
                                    >
                                    <option value="parous_no_gdm"
                                        >Con rạ — KHÔNG có tiền sử GDM</option
                                    >
                                    <option value="parous_prev_gdm"
                                        >Con rạ — CÓ tiền sử GDM</option
                                    >
                                </select>
                                <small class="form-help"
                                    >Nếu CÓ tiền sử GDM: nguy cơ rất cao, chỉ
                                    cần cân nặng mẹ.</small>
                            </div>
                            <div class="form-group" id="fmf-bw-group" hidden>
                                <label for="fmf-bw-zscore" class="form-label"
                                    >Z-score cân nặng con lần trước</label
                                ><input
                                    type="number"
                                    id="fmf-bw-zscore"
                                    class="form-input"
                                    step="0.1"
                                    placeholder="VD: 0.5"
                                /><small class="form-help"
                                    >Nếu không biết, để trống (mặc định = 0).</small>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Hút thuốc?</label>
                                <div class="toggle-group toggle-sm">
                                    <label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="fmf-smoking"
                                            value="no"
                                            checked
                                        /><span>Không</span>
                                    </label>
                                    <label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="fmf-smoking"
                                            value="yes"
                                        /><span>Có</span>
                                    </label>
                                </div>
                            </div>
                            <div
                                id="fmf-error"
                                class="validation-error"
                                role="alert"
                                aria-live="polite"
                                hidden
                            >
                            </div>
                            <button
                                type="submit"
                                class="btn btn-primary btn-lg calc-submit"
                                id="fmf-submit">Phân Tích Nguy Cơ FMF</button
                            >
                        </form>
                    </div>
                </div>

                <!-- ═══ TAB B: PersonalGDM Outcomes ═══ -->
                <div
                    class="tab-panel"
                    id="panel-outcomes"
                    role="tabpanel"
                    hidden
                >
                    <div class="calc-input-panel card">
                        <h2 class="calc-panel-title">
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="var(--primary)"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                aria-hidden="true"
                                ><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
                            </svg> PersonalGDM Outcomes — Đã chẩn đoán GDM
                        </h2>
                        <form id="outcomes-form" novalidate>
                            <div class="form-section-label">
                                Thông tin cơ bản
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="out-age" class="form-label"
                                        >Tuổi mẹ</label
                                    ><input
                                        type="number"
                                        id="out-age"
                                        class="form-input"
                                        min="14"
                                        max="60"
                                        placeholder="VD: 30"
                                        required
                                    />
                                </div>
                                <div class="form-group">
                                    <label for="out-bmi" class="form-label"
                                        >BMI trước thai (kg/m²)</label
                                    ><input
                                        type="number"
                                        id="out-bmi"
                                        class="form-input"
                                        min="12"
                                        max="70"
                                        step="0.1"
                                        placeholder="VD: 24"
                                        required
                                    />
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="out-ethnicity" class="form-label"
                                    >Dân tộc</label
                                >
                                <select id="out-ethnicity" class="form-input">
                                    <option value="caucasian_eu"
                                        >Caucasian / Châu Âu</option
                                    >
                                    <option value="south_central_asian"
                                        >Trung/Nam Á</option
                                    >
                                    <option value="east_asian" selected
                                        >Đông Á (Việt Nam)</option
                                    >
                                    <option value="african">Châu Phi</option>
                                    <option value="oceanian"
                                        >Châu Đại Dương</option
                                    >
                                    <option value="other">Khác</option>
                                </select>
                            </div>
                            <hr class="form-divider" />
                            <div class="form-section-label">
                                Kết quả OGTT 75g
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="out-fasting" class="form-label"
                                        >Glucose đói (mmol/L)</label
                                    ><input
                                        type="number"
                                        id="out-fasting"
                                        class="form-input"
                                        min="0"
                                        max="20"
                                        step="0.1"
                                        placeholder="VD: 5.1"
                                        required
                                    /><small class="form-help"
                                        >mg/dL → mmol/L: nhân × 0.0555</small>
                                </div>
                                <div class="form-group">
                                    <label for="out-1h" class="form-label"
                                        >Glucose 1 giờ (mmol/L)</label
                                    ><input
                                        type="number"
                                        id="out-1h"
                                        class="form-input"
                                        min="0"
                                        max="30"
                                        step="0.1"
                                        placeholder="VD: 10.0"
                                        required
                                    />
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="out-ga-diag" class="form-label"
                                        >Tuổi thai chẩn đoán (tuần)</label
                                    ><input
                                        type="number"
                                        id="out-ga-diag"
                                        class="form-input"
                                        min="10"
                                        max="40"
                                        placeholder="VD: 26"
                                        required
                                    />
                                </div>
                                <div class="form-group">
                                    <label
                                        for="out-weight-gain"
                                        class="form-label"
                                        >Tổng tăng cân (kg)</label
                                    ><input
                                        type="number"
                                        id="out-weight-gain"
                                        class="form-input"
                                        min="0"
                                        max="40"
                                        step="0.1"
                                        placeholder="VD: 8"
                                        required
                                    /><small class="form-help"
                                        >Từ đầu thai kỳ → chẩn đoán GDM</small>
                                </div>
                            </div>
                            <hr class="form-divider" />
                            <div class="form-section-label">Tiền sử</div>
                            <div class="checkbox-grid">
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="out-nulliparous"
                                    /><span>Con so (chưa sinh lần nào)</span>
                                </label>
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="out-prev-lga"
                                    /><span
                                        >Tiền sử sinh con to (LGA &gt;90th
                                        percentile)</span
                                    >
                                </label>
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="out-prev-pe"
                                    /><span>Tiền sử tiền sản giật/sản giật</span
                                    >
                                </label>
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="out-family-dm"
                                    /><span>Tiền sử gia đình ĐTĐ</span>
                                </label>
                            </div>
                            <div
                                id="out-error"
                                class="validation-error"
                                role="alert"
                                aria-live="polite"
                                hidden
                            >
                            </div>
                            <button
                                type="submit"
                                class="btn btn-primary btn-lg calc-submit"
                                >Phân Tích Nguy Cơ Biến Cố</button
                            >
                        </form>
                    </div>
                </div>

                <!-- ═══ TAB C: Iowa Nulliparous ═══ -->
                <div class="tab-panel" id="panel-iowa" role="tabpanel" hidden>
                    <div class="calc-input-panel card">
                        <h2 class="calc-panel-title">
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="var(--primary)"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                aria-hidden="true"
                                ><circle cx="12" cy="12" r="10"></circle><path
                                    d="M12 6v6l4 2"></path>
                            </svg> Iowa GDM Risk — Phụ nữ con so
                        </h2>
                        <form id="iowa-form" novalidate>
                            <div class="form-section-label">
                                Thông tin bệnh nhân
                            </div>
                            <div class="form-group">
                                <label for="iowa-ethnicity" class="form-label"
                                    >Chủng tộc</label
                                >
                                <select id="iowa-ethnicity" class="form-input">
                                    <option value="white"
                                        >White, not Hispanic</option
                                    >
                                    <option value="hispanic">Hispanic</option>
                                    <option value="black">Black</option>
                                    <option value="asian" selected
                                        >Asian (bao gồm Việt Nam)</option
                                    >
                                    <option value="ai_an"
                                        >American Indian/Alaska Native</option
                                    >
                                    <option value="hawaiian_pi"
                                        >Hawaiian/Pacific Islander</option
                                    >
                                    <option value="other">Khác</option>
                                </select>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="iowa-age" class="form-label"
                                        >Tuổi mẹ</label
                                    ><input
                                        type="number"
                                        id="iowa-age"
                                        class="form-input"
                                        min="14"
                                        max="60"
                                        placeholder="VD: 30"
                                        required
                                    />
                                </div>
                                <div class="form-group">
                                    <label for="iowa-bmi" class="form-label"
                                        >BMI trước thai</label
                                    ><input
                                        type="number"
                                        id="iowa-bmi"
                                        class="form-input"
                                        min="12"
                                        max="70"
                                        step="0.1"
                                        placeholder="VD: 24"
                                        required
                                    />
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label"
                                        >Tiền sử gia đình ĐTĐ?</label
                                    >
                                    <div class="toggle-group toggle-sm">
                                        <label class="radio-card"
                                            ><input
                                                type="radio"
                                                name="iowa-family-dm"
                                                value="no"
                                                checked
                                            /><span>Không</span>
                                        </label><label class="radio-card"
                                            ><input
                                                type="radio"
                                                name="iowa-family-dm"
                                                value="yes"
                                            /><span>Có</span>
                                        </label>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="form-label"
                                        >Tăng HA có từ trước?</label
                                    >
                                    <div class="toggle-group toggle-sm">
                                        <label class="radio-card"
                                            ><input
                                                type="radio"
                                                name="iowa-htn"
                                                value="no"
                                                checked
                                            /><span>Không</span>
                                        </label><label class="radio-card"
                                            ><input
                                                type="radio"
                                                name="iowa-htn"
                                                value="yes"
                                            /><span>Có</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <div
                                id="iowa-error"
                                class="validation-error"
                                role="alert"
                                aria-live="polite"
                                hidden
                            >
                            </div>
                            <button
                                type="submit"
                                class="btn btn-primary btn-lg calc-submit"
                                >Phân Tích Nguy Cơ Iowa</button
                            >
                        </form>
                    </div>
                </div>

                <!-- ═══ RESULTS PANEL ═══ -->
                <div class="calc-results-panel" id="results-panel" hidden>
                    <div
                        class="result-card result-primary card"
                        id="risk-header"
                    >
                        <div class="result-icon-wrap">
                            <span class="result-emoji" id="risk-emoji">⚠️</span>
                        </div>
                        <div class="result-content">
                            <span class="result-label" id="result-model-label"
                                >Phân tầng nguy cơ</span
                            >
                            <div class="result-risk-level" id="risk-level">
                                --
                            </div>
                            <div class="result-sub" id="risk-action"></div>
                        </div>
                    </div>

                    <!-- Risk Value Card -->
                    <div class="card result-card">
                        <h3 class="card-title">
                            <svg
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="var(--primary)"
                                stroke-width="2"
                                aria-hidden="true"
                                ><polyline
                                    points="22 12 18 12 15 21 9 3 6 12 2 12"
                                ></polyline>
                            </svg> Chi tiết kết quả
                        </h3>
                        <div id="risk-detail-content"></div>
                    </div>

                    <!-- Threshold Table -->
                    <div class="card result-card" id="threshold-card">
                        <h3 class="card-title">
                            <svg
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="var(--primary)"
                                stroke-width="2"
                                aria-hidden="true"
                                ><rect
                                    x="3"
                                    y="3"
                                    width="18"
                                    height="18"
                                    rx="2"
                                    ry="2"></rect><line
                                    x1="3"
                                    y1="9"
                                    x2="21"
                                    y2="9"></line><line
                                    x1="9"
                                    y1="21"
                                    x2="9"
                                    y2="9"></line>
                            </svg> Bảng phân tầng nguy cơ
                        </h3>
                        <div
                            class="threshold-table-wrap"
                            id="threshold-table-wrap"
                        >
                        </div>
                    </div>

                    <!-- Prompt -->
                    <div class="card result-card prompt-card">
                        <h3 class="card-title">
                            <svg
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="var(--accent)"
                                stroke-width="2"
                                aria-hidden="true"
                                ><path
                                    d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"
                                ></path>
                            </svg> Prompt cho AI — Gợi ý lâm sàng
                        </h3>
